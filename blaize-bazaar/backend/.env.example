# Database Configuration
DB_HOST=your-cluster.cluster-xxxxx.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-secure-password

# Database URL (alternative to individual params)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# AWS Configuration
AWS_REGION=us-west-2

# Aurora Cluster ARN (for RDS Data API if needed)
DB_CLUSTER_ARN=arn:aws:rds:us-west-2:123456789012:cluster:blaize-bazaar-cluster

# Secrets Manager (for credentials)
DB_SECRET_ARN=arn:aws:secretsmanager:us-west-2:123456789012:secret:blaize-bazaar-db-secret

# Bedrock Configuration
BEDROCK_EMBEDDING_MODEL=us.cohere.embed-v4:0
BEDROCK_RERANK_MODEL=cohere.rerank-v3-5:0
BEDROCK_CHAT_MODEL=global.anthropic.claude-sonnet-4-6

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL=INFO

# AgentCore (provisioned by bootstrap)
AGENTCORE_MEMORY_ID=
AGENTCORE_GATEWAY_URL=
AGENTCORE_GATEWAY_API_KEY=workshop

# Bedrock Guardrails (Wire It Live / Lab 3)
# Guardrail resource to apply to agent input and output. Leave empty to
# run in pass-through mode (logs "guardrails disabled" at startup).
# Version defaults to DRAFT; set to a published version (e.g. "1") in prod.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT